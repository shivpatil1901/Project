FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements_pipeline.txt ./requirements_pipeline.txt
RUN pip install --upgrade pip && pip install -r requirements_pipeline.txt

COPY src ./src
COPY streamlit_app.py ./streamlit_app.py

EXPOSE 8000

CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
